<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base app theme. Actual UI colors are driven by Compose (graincore palette);
         this XML theme only sets the pre-Compose window background so launch is dark. -->
    <style name="Theme.Tumble" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/graincore_blue</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>
